DISCORD_TOKEN=your_discord_bot_token

# Optional. Recommended during development because guild commands update instantly.
DISCORD_GUILD_ID=

# Defaults are fine for most installs.
DATABASE_PATH=./data/beebs.sqlite
BEEBS_SITEMAP_URL=https://www.beebs.app/api/sitemaps/products/last-created/0
CHECK_INTERVAL_MS=120000
ENABLE_PLAYWRIGHT=false
ENABLE_CATEGORY_FILTER=false
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_USER_DATA_DIR=./data/playwright-profile
NAVIGATION_TIMEOUT_MS=45000
MAX_LISTINGS_PER_CHECK=20
MAX_LISTING_AGE_MINUTES=10
SITEMAP_SCAN_LIMIT=10000
SCRAPER_RETRY_ATTEMPTS=3
SCRAPER_DELAY_MIN_MS=500
SCRAPER_DELAY_MAX_MS=2000
SEEN_KEY_LOOKUP_LIMIT=500
